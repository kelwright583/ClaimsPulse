generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── Auth & Users ──────────────────────────────────────────────────────────────

model Profile {
  id        String   @id @db.Uuid
  email     String
  fullName  String?  @map("full_name")
  role      UserRole @default(CLAIMS_TECHNICIAN)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  acknowledgedDelays AcknowledgedDelay[]
  importRuns         ImportRun[]

  @@map("profiles")
}

enum UserRole {
  SENIOR_MANAGEMENT
  HEAD_OF_CLAIMS
  TEAM_LEADER
  CLAIMS_TECHNICIAN
  TP_HANDLER
  SALVAGE_HANDLER
  MAILBOX_ADMIN
  UW_ANALYST

  @@map("user_role")
}

// ── Import tracking ───────────────────────────────────────────────────────────

model ImportRun {
  id          String     @id @default(uuid()) @db.Uuid
  reportType  ReportType @map("report_type")
  filename    String
  uploadedBy  String?    @map("uploaded_by") @db.Uuid
  rowsRead    Int        @default(0) @map("rows_read")
  rowsCreated Int        @default(0) @map("rows_created")
  rowsUpdated Int        @default(0) @map("rows_updated")
  rowsSkipped Int        @default(0) @map("rows_skipped")
  rowsErrored Int        @default(0) @map("rows_errored")
  errorsJson  Json?      @map("errors_json")
  periodStart DateTime?  @map("period_start")
  periodEnd   DateTime?  @map("period_end")
  createdAt   DateTime   @default(now()) @map("created_at")

  uploader Profile? @relation(fields: [uploadedBy], references: [id])

  snapshots          ClaimSnapshot[]
  flags              ClaimFlag[]
  payments           Payment[]
  premiumRecords     PremiumRecord[]
  financialSummaries FinancialSummary[]
  policyCounts       PolicyCount[]
  uwSnapshots        UwSnapshot[]

  @@index([reportType])
  @@index([createdAt])
  @@map("import_runs")
}

enum ReportType {
  CLAIMS_OUTSTANDING
  PAYEE
  REVENUE_ANALYSIS
  MOVEMENT_SUMMARY
  CLAIMS_REGISTER

  @@map("report_type")
}

// ── Claims snapshots ──────────────────────────────────────────────────────────
// One row per claim per daily import. This is the core historical record.

model ClaimSnapshot {
  id           String   @id @default(uuid()) @db.Uuid
  importRunId  String   @map("import_run_id") @db.Uuid
  snapshotDate DateTime @map("snapshot_date") @db.Date
  claimId      String   @map("claim_id")
  oldClaimId   String?  @map("old_claim_id")

  // Handler & status
  handler         String?
  claimStatus     String?  @map("claim_status")
  secondaryStatus String?  @map("secondary_status")

  // Classification
  orgUnit     String? @map("org_unit")
  uwYear      Int?    @map("uw_year")
  groupCode   String? @map("group_code")
  groupDesc   String? @map("group_desc")
  sectionDesc String? @map("section_desc")
  productLine String? @map("product_line")

  // Policy & insured
  policyNumber String? @map("policy_number")
  insured      String?
  broker       String?

  // Dates
  dateOfLoss         DateTime? @map("date_of_loss") @db.Date
  dateOfNotification DateTime? @map("date_of_notification") @db.Date
  dateOfRegistration DateTime? @map("date_of_registration") @db.Date

  // Cause & location
  cause    String?
  lossArea String? @map("loss_area")
  lossAddr String? @map("loss_addr")

  // Reserve
  intimatedAmount Decimal? @map("intimated_amount") @db.Decimal(18, 2)
  retainedPct     Decimal? @map("retained_pct") @db.Decimal(10, 6)
  deductible      Decimal? @db.Decimal(18, 2)

  // Paid breakdown
  ownDamagePaid     Decimal? @map("own_damage_paid") @db.Decimal(18, 2)
  thirdPartyPaid    Decimal? @map("third_party_paid") @db.Decimal(18, 2)
  expensesPaid      Decimal? @map("expenses_paid") @db.Decimal(18, 2)
  legalCostsPaid    Decimal? @map("legal_costs_paid") @db.Decimal(18, 2)
  assessorFeesPaid  Decimal? @map("assessor_fees_paid") @db.Decimal(18, 2)
  repairAuthPaid    Decimal? @map("repair_auth_paid") @db.Decimal(18, 2)
  cashLieuPaid      Decimal? @map("cash_lieu_paid") @db.Decimal(18, 2)
  glassAuthPaid     Decimal? @map("glass_auth_paid") @db.Decimal(18, 2)
  partsAuthPaid     Decimal? @map("parts_auth_paid") @db.Decimal(18, 2)
  towingPaid        Decimal? @map("towing_paid") @db.Decimal(18, 2)
  additionalsPaid   Decimal? @map("additionals_paid") @db.Decimal(18, 2)
  tpLiabilityPaid   Decimal? @map("tp_liability_paid") @db.Decimal(18, 2)
  investigationPaid Decimal? @map("investigation_paid") @db.Decimal(18, 2)
  totalPaid         Decimal? @map("total_paid") @db.Decimal(18, 2)
  totalRecovery     Decimal? @map("total_recovery") @db.Decimal(18, 2)
  totalSalvage      Decimal? @map("total_salvage") @db.Decimal(18, 2)

  // Outstanding breakdown
  ownDamageOs    Decimal? @map("own_damage_os") @db.Decimal(18, 2)
  thirdPartyOs   Decimal? @map("third_party_os") @db.Decimal(18, 2)
  expensesOs     Decimal? @map("expenses_os") @db.Decimal(18, 2)
  legalCostsOs   Decimal? @map("legal_costs_os") @db.Decimal(18, 2)
  assessorFeesOs Decimal? @map("assessor_fees_os") @db.Decimal(18, 2)
  repairAuthOs   Decimal? @map("repair_auth_os") @db.Decimal(18, 2)
  cashLieuOs     Decimal? @map("cash_lieu_os") @db.Decimal(18, 2)
  glassAuthOs    Decimal? @map("glass_auth_os") @db.Decimal(18, 2)
  tpLiabilityOs  Decimal? @map("tp_liability_os") @db.Decimal(18, 2)
  totalOs        Decimal? @map("total_os") @db.Decimal(18, 2)

  // Totals
  totalIncurred     Decimal? @map("total_incurred") @db.Decimal(18, 2)
  sectionSumInsured Decimal? @map("section_sum_insured") @db.Decimal(18, 2)

  // Computed on insert
  notificationGapDays   Int?     @map("notification_gap_days")
  reserveUtilisationPct Decimal? @map("reserve_utilisation_pct") @db.Decimal(8, 2)
  complexityWeight      Int?     @map("complexity_weight")
  deltaFlags            Json?    @map("delta_flags")
  isTatBreach           Boolean  @default(false) @map("is_tat_breach")
  daysInCurrentStatus   Int?     @map("days_in_current_status")
  daysOpen              Int?     @map("days_open")
  isStub        Boolean  @default(false) @map("is_stub")
  isCatastrophe Boolean  @default(false) @map("is_catastrophe")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@unique([claimId, snapshotDate])
  @@index([claimId])
  @@index([snapshotDate])
  @@index([handler])
  @@index([claimStatus])
  @@index([secondaryStatus])
  @@index([cause])
  @@index([broker])
  @@index([isTatBreach])
  @@index([importRunId])
  @@index([isStub])
  @@map("claim_snapshots")
}

// ── Payments (Report 2) ───────────────────────────────────────────────────────

model Payment {
  id               String    @id @default(uuid()) @db.Uuid
  importRunId      String    @map("import_run_id") @db.Uuid
  claimId          String    @map("claim_id")
  handler          String?
  chequeNo         String?   @map("cheque_no")
  payee            String?
  payeeVatNr       String?   @map("payee_vat_nr")
  paymentType      String?   @map("payment_type")
  requestedBy      String?   @map("requested_by")
  requestedDate    DateTime? @map("requested_date") @db.Date
  authorisedDate   DateTime? @map("authorised_date") @db.Date
  printedDate      DateTime? @map("printed_date") @db.Date
  grossPaidInclVat Decimal?  @map("gross_paid_incl_vat") @db.Decimal(18, 2)
  grossPaidExclVat Decimal?  @map("gross_paid_excl_vat") @db.Decimal(18, 2)
  netPaidInclVat   Decimal?  @map("net_paid_incl_vat") @db.Decimal(18, 2)
  broker           String?
  policyNumber     String?   @map("policy_number")
  insured          String?
  claimStatus      String?   @map("claim_status")

  // Computed integrity flags
  sameDayAuthPrint   Boolean @default(false) @map("same_day_auth_print")
  selfAuthorised     Boolean @default(false) @map("self_authorised")
  daysRequestToprint Int?    @map("days_request_to_print")

  createdAt DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([payeeVatNr])
  @@index([requestedBy])
  @@index([printedDate])
  @@map("payments")
}

// ── Premium records (Report 3) ────────────────────────────────────────────────

model PremiumRecord {
  id              String   @id @default(uuid()) @db.Uuid
  importRunId     String   @map("import_run_id") @db.Uuid
  month           String
  periodDate      DateTime @map("period_date") @db.Date
  branch          String?
  classCode       String?  @map("class_code")
  className       String?  @map("class_name")
  product         String?
  broker          String?
  policyNumber    String?  @map("policy_number")
  insured         String?
  uwYear          Int?     @map("uw_year")
  endorsementType String?  @map("endorsement_type")
  gwp             Decimal? @db.Decimal(18, 2)
  netWp           Decimal? @map("net_wp") @db.Decimal(18, 2)
  quotaShareWp    Decimal? @map("quota_share_wp") @db.Decimal(18, 2)
  gwpVat          Decimal? @map("gwp_vat") @db.Decimal(18, 2)
  grossComm       Decimal? @map("gross_comm") @db.Decimal(18, 2)
  netComm         Decimal? @map("net_comm") @db.Decimal(18, 2)
  grossCommPct    Decimal? @map("gross_comm_pct") @db.Decimal(8, 4)
  currency        String?  @default("ZAR")
  createdAt       DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([periodDate])
  @@index([broker])
  @@index([className])
  @@index([endorsementType])
  @@map("premium_records")
}

// ── Financial summaries (Report 4) ────────────────────────────────────────────

model FinancialSummary {
  id          String   @id @default(uuid()) @db.Uuid
  importRunId String   @map("import_run_id") @db.Uuid
  period      String
  periodDate  DateTime @map("period_date") @db.Date
  section     String
  level       String
  metric      String
  value       Decimal  @db.Decimal(18, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@unique([periodDate, section, level, metric])
  @@index([periodDate])
  @@index([section])
  @@map("financial_summaries")
}

// ── TAT Configuration ─────────────────────────────────────────────────────────

model TatConfig {
  id              String   @id @default(uuid()) @db.Uuid
  secondaryStatus String   @unique @map("secondary_status")
  maxDays         Int      @map("max_days")
  alertRole       String   @map("alert_role")
  priority        String   @default("standard")
  isActive        Boolean  @default(true) @map("is_active")
  updatedBy       String?  @map("updated_by") @db.Uuid
  updatedAt       DateTime @updatedAt @map("updated_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("tat_config")
}

// ── Acknowledged Delays ───────────────────────────────────────────────────────

model AcknowledgedDelay {
  id              String    @id @default(uuid()) @db.Uuid
  claimId         String    @map("claim_id")
  secondaryStatus String    @map("secondary_status")
  reasonType      String    @map("reason_type")
  note            String?   @db.Text
  expectedDate    DateTime  @map("expected_date") @db.Date
  loggedBy        String    @map("logged_by") @db.Uuid
  loggedAt        DateTime  @default(now()) @map("logged_at")
  resolvedAt      DateTime? @map("resolved_at")
  isActive        Boolean   @default(true) @map("is_active")
  isOverdue       Boolean   @default(false) @map("is_overdue")

  logger Profile @relation(fields: [loggedBy], references: [id])

  @@index([claimId])
  @@index([isActive])
  @@index([expectedDate])
  @@index([loggedBy])
  @@map("acknowledged_delays")
}

// ── Claim Flags ───────────────────────────────────────────────────────────────

model ClaimFlag {
  id          String   @id @default(uuid()) @db.Uuid
  importRunId String   @map("import_run_id") @db.Uuid
  claimId     String   @map("claim_id")
  flagType    FlagType @map("flag_type")
  severity    String   @default("warning")
  detail      Json?
  createdAt   DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([claimId])
  @@index([flagType])
  @@index([importRunId])
  @@map("claim_flags")
}

enum FlagType {
  BIG_CLAIM
  RESERVE_UNDER
  RESERVE_OVER
  DUPLICATE_INSURED
  DUPLICATE_PAYEE_VAT
  CASH_LIEU_AND_REPAIR
  SAME_DAY_AUTH_PRINT
  SELF_AUTHORISED
  VALUE_CREEP
  REOPENED
  UNASSIGNED
  TAT_BREACH
  NO_PAYMENT_30_DAYS

  @@map("flag_type")
}

// ── Claim Actions (post-claim obligations) ────────────────────────────────────

model ClaimAction {
  id          String    @id @default(uuid()) @db.Uuid
  claimId     String    @map("claim_id")
  actionType  String    @map("action_type") // 'write_off' | 'excess_collected' | 'tp_instructed' | 'salvage_referred' | 'uw_notified' | 'repairer_chased'
  isComplete  Boolean   @default(false) @map("is_complete")
  completedAt DateTime? @map("completed_at")
  completedBy String?   @map("completed_by") @db.Uuid
  note        String?   @db.Text
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([claimId])
  @@index([actionType])
  @@index([isComplete])
  @@map("claim_actions")
}

// ── Handler Targets ───────────────────────────────────────────────────────────

model HandlerTarget {
  id           String   @id @default(uuid()) @db.Uuid
  handler      String
  metricType   String   @map("metric_type")
  targetValue  Decimal  @map("target_value") @db.Decimal(18, 4)
  setBy        String?  @map("set_by") @db.Uuid
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([handler, metricType])
  @@index([handler])
  @@index([metricType])
  @@map("handler_targets")
}

model TargetMetricConfig {
  id          String   @id @default(uuid()) @db.Uuid
  metricType  String   @unique @map("metric_type")
  label       String
  unit        String
  cadence     String
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("target_metric_config")
}

// ── Generated Reports ─────────────────────────────────────────────────────────

model GeneratedReport {
  id           String   @id @default(uuid()) @db.Uuid
  reportType   String   @map("report_type")
  title        String
  parameters   Json
  format       String
  fileUrl      String?  @map("file_url")
  generatedBy  String   @map("generated_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([generatedBy])
  @@index([createdAt])
  @@map("generated_reports")
}

// ── Targets ───────────────────────────────────────────────────────────────────

model Target {
  id           String   @id @default(uuid()) @db.Uuid
  metricType   String   @map("metric_type") // 'loss_ratio' | 'net_wp' | 'policy_count'
  productLine  String?  @map("product_line") // null = aggregate
  uwYear       Int      @map("uw_year")
  annualTarget Decimal  @map("annual_target") @db.Decimal(18, 2)
  setBy        String?  @map("set_by") @db.Uuid
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([metricType, productLine, uwYear])
  @@map("targets")
}

// ── Policy Counts ─────────────────────────────────────────────────────────────

model PolicyCount {
  id            String   @id @default(uuid()) @db.Uuid
  importRunId   String   @map("import_run_id") @db.Uuid
  month         String
  periodDate    DateTime @map("period_date") @db.Date
  productLine   String?  @map("product_line")
  inForce       Int?     @map("in_force")
  newBusiness   Int?     @map("new_business")
  renewals      Int?     @map("renewals")
  lapses        Int?     @map("lapses")
  netMovement   Int?     @map("net_movement")
  isApproximate Boolean  @default(false) @map("is_approximate")
  createdAt     DateTime @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@unique([periodDate, productLine])
  @@map("policy_counts")
}

// ── Triage / Mailbox Models ────────────────────────────────────────────────────

model MailboxConfig {
  id                        String   @id @default(uuid()) @db.Uuid
  departmentName            String   @map("department_name")
  mailboxAddress            String   @map("mailbox_address")
  active                    Boolean  @default(true)
  classificationInstructions String? @map("classification_instructions") @db.Text
  urgentKeywords            String[] @map("urgent_keywords")
  isConfigured              Boolean  @default(false) @map("is_configured")
  createdAt                 DateTime @default(now()) @map("created_at")

  categories   RoutingCategory[]
  staff        MailboxStaff[]
  rules        RoutingRule[]
  emailRecords EmailRecord[]

  @@map("mailbox_configs")
}

model RoutingCategory {
  id           String  @id @default(uuid()) @db.Uuid
  mailboxId    String  @map("mailbox_id") @db.Uuid
  name         String
  description  String? @db.Text
  colour       String  @default("#6B7280")
  displayOrder Int     @default(0) @map("display_order")

  mailbox MailboxConfig @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  rule    RoutingRule?

  @@map("routing_categories")
}

model MailboxStaff {
  id              String  @id @default(uuid()) @db.Uuid
  mailboxId       String  @map("mailbox_id") @db.Uuid
  name            String
  email           String
  isTeamLeader    Boolean @default(false) @map("is_team_leader")
  isInRoundRobin  Boolean @default(true) @map("is_in_round_robin")
  roundRobinOrder Int?    @map("round_robin_order")
  active          Boolean @default(true)

  mailbox MailboxConfig @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@map("mailbox_staff")
}

model RoutingRule {
  id                   String  @id @default(uuid()) @db.Uuid
  mailboxId            String  @map("mailbox_id") @db.Uuid
  categoryId           String  @unique @map("category_id") @db.Uuid
  categoryName         String  @map("category_name")
  destinationFolderId  String? @map("destination_folder_id")
  destinationFolderName String? @map("destination_folder_name")
  alwaysUrgent         Boolean @default(false) @map("always_urgent")
  notifyTeamLeader     Boolean @default(false) @map("notify_team_leader")
  autoAcknowledge      Boolean @default(false) @map("auto_acknowledge")
  acknowledgeTemplate  String? @map("acknowledge_template") @db.Text
  tatMinutes           Int     @default(1440) @map("tat_minutes")
  useRoundRobin        Boolean @default(true) @map("use_round_robin")
  fixedAssigneeEmail   String? @map("fixed_assignee_email")
  active               Boolean @default(true)

  mailbox  MailboxConfig   @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  category RoutingCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("routing_rules")
}

model EmailRecord {
  id             String    @id @default(uuid()) @db.Uuid
  mailboxId      String    @map("mailbox_id") @db.Uuid
  graphEmailId   String    @unique @map("graph_email_id")
  subject        String?
  categoryName   String?   @map("category_name")
  senderType     String?   @map("sender_type")
  urgent         Boolean   @default(false)
  confidence     Decimal?  @db.Decimal(5, 2)
  receivedAt     DateTime  @map("received_at")
  tatDeadline    DateTime  @map("tat_deadline")
  respondedTo    Boolean   @default(false) @map("responded_to")
  respondedAt    DateTime? @map("responded_at")
  tatAlertSent   Boolean   @default(false) @map("tat_alert_sent")
  assignedToEmail String?  @map("assigned_to_email")
  claimId        String?   @map("claim_id")

  mailbox MailboxConfig @relation(fields: [mailboxId], references: [id])

  @@index([graphEmailId])
  @@index([categoryName])
  @@index([tatDeadline])
  @@index([claimId])
  @@map("email_records")
}

model MailboxAuditLog {
  id           String    @id @default(uuid()) @db.Uuid
  mailboxId    String    @map("mailbox_id") @db.Uuid
  graphEmailId String    @map("graph_email_id")
  subject      String?
  categoryName String?   @map("category_name")
  urgent       Boolean   @default(false)
  senderType   String?   @map("sender_type")
  confidence   Decimal?  @db.Decimal(5, 2)
  reasoning    String?   @db.Text
  actionTaken  String?   @map("action_taken")
  assignedTo   String?   @map("assigned_to")
  claimId      String?   @map("claim_id")
  timestamp    DateTime  @default(now())

  @@index([timestamp])
  @@index([categoryName])
  @@index([claimId])
  @@map("mailbox_audit_logs")
}

// ── Underwriting Models ────────────────────────────────────────────────────────

model UwSnapshot {
  id          String    @id @default(uuid()) @db.Uuid
  importRunId String    @map("import_run_id") @db.Uuid
  periodDate  DateTime  @map("period_date") @db.Date
  productLine String?   @map("product_line")
  broker      String?
  gwp         Decimal?  @db.Decimal(18, 2)
  netWp       Decimal?  @map("net_wp") @db.Decimal(18, 2)
  policyCount Int?      @map("policy_count")
  newBusiness Int?      @map("new_business")
  renewals    Int?
  lapses      Int?
  createdAt   DateTime  @default(now()) @map("created_at")

  importRun ImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)

  @@index([periodDate])
  @@index([productLine])
  @@index([broker])
  @@map("uw_snapshots")
}


// ── Operations: Projects ───────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  ACTIVE
  BLOCKED
  COMPLETE
  @@map("project_status")
}

enum ProjectPriority {
  HIGH
  MEDIUM
  LOW
  @@map("project_priority")
}

model Project {
  id          String          @id @default(uuid()) @db.Uuid
  title       String
  description String?         @db.Text
  status      ProjectStatus   @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  ownerId     String          @map("owner_id") @db.Uuid
  pillarLink  String?         @map("pillar_link")
  metricLink  String?         @map("metric_link")
  startDate   DateTime?       @map("start_date") @db.Date
  dueDate     DateTime?       @map("due_date") @db.Date
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  milestones   ProjectMilestone[]
  deliverables ProjectDeliverable[]
  updates      ProjectUpdate[]
  documents    ProjectDocument[]

  @@index([status])
  @@index([ownerId])
  @@index([dueDate])
  @@map("projects")
}

model ProjectMilestone {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  title       String
  dueDate     DateTime  @map("due_date") @db.Date
  isComplete  Boolean   @default(false) @map("is_complete")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([dueDate])
  @@map("project_milestones")
}

model ProjectDeliverable {
  id           String    @id @default(uuid()) @db.Uuid
  projectId    String    @map("project_id") @db.Uuid
  title        String
  isComplete   Boolean   @default(false) @map("is_complete")
  completedAt  DateTime? @map("completed_at")
  completedBy  String?   @map("completed_by") @db.Uuid
  displayOrder Int       @default(0) @map("display_order")
  createdAt    DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_deliverables")
}

model ProjectUpdate {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  authorId  String   @map("author_id") @db.Uuid
  body      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_updates")
}

model ProjectDocument {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  title       String
  description String?
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  fileSizeKb  Int?     @map("file_size_kb")
  tags        String[] @default([])
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("project_documents")
}
